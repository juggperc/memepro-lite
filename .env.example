# memepro.lite - Environment Variables

# 1. Solana RPC (Mainnet)
# Get a free key at https://www.helius.dev/
NEXT_PUBLIC_SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=your-key-here
NEXT_PUBLIC_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-key-here

# 2. Helius API (On-chain holder data)
NEXT_PUBLIC_HELIUS_API_KEY=your-key-here

# 3. P2P Casino Escrow (Server-side ONLY)
# Run 'npx ts-node scripts/generate-escrow-keypair.ts' to generate
ESCROW_SECRET_KEY=your-base64-secret-key
NEXT_PUBLIC_ESCROW_WALLET=your-escrow-public-key

# 4. Database (Vercel Postgres / Neon)
# Auto-populated on Vercel. For local, use a Neon DB URL.
POSTGRES_URL=postgres://user:pass@host/db
