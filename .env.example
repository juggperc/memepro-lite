# RPC endpoint for Solana mainnet (optional - defaults to public endpoint)
NEXT_PUBLIC_RPC_URL=

# PumpPortal API (optional - for future features)
PUMPPORTAL_API_KEY=

# Database (Vercel Postgres / Neon - required for P2P games)
# These are auto-populated when you add Postgres via Vercel dashboard
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
