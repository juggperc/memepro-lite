{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/holders/[mint]",
      "regex": "^/api/holders/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPmint": "nxtPmint"
      },
      "namedRegex": "^/api/holders/(?<nxtPmint>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/p2p/lobbies/[id]/cancel",
      "regex": "^/api/p2p/lobbies/([^/]+?)/cancel(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/p2p/lobbies/(?<nxtPid>[^/]+?)/cancel(?:/)?$"
    },
    {
      "page": "/api/p2p/lobbies/[id]/join",
      "regex": "^/api/p2p/lobbies/([^/]+?)/join(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/p2p/lobbies/(?<nxtPid>[^/]+?)/join(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api/p2p/game/flip",
      "regex": "^/api/p2p/game/flip(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/p2p/game/flip(?:/)?$"
